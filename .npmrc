# Hoist workbox-* so vite-plugin-pwa can resolve the virtual `workbox-window`
# module from the web app's node_modules. vite-plugin-pwa declares these as
# peers AND as regular deps, but Vite/Rollup resolves the import relative to
# apps/web/ so pnpm's default strict layout hides them.
public-hoist-pattern[]=*workbox*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/*
