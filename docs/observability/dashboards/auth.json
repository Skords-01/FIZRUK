  "panels": [
    {
      "title": "Auth outcomes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "$DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (op, outcome) (rate(auth_attempts_total[5m]))",
          "legendFormat": "{{op}} — {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Session lookup p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "$DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "sli:auth_session_lookup_p95_ms:rate5m",
          "legendFormat": "p95 session lookup",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate-limit hits on api:auth:sensitive",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "$DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(rate_limit_hits_total{key=~\"api:auth:.*\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Sign-in success rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "$DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(rate(auth_attempts_total{op=\"sign_in\",outcome=\"ok\"}[1h])) / clamp_min(sum(rate(auth_attempts_total{op=\"sign_in\"}[1h])), 1)",
          "legendFormat": "sign-in success rate (1h)",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["sergeant", "auth"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
