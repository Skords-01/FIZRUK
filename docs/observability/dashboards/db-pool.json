      "title": "runbook.md",
      "tooltip": "Incident Runbook",
      "type": "link",
      "url": "https://github.com/Skords-01/Sergeant/blob/main/docs/observability/runbook.md"
    }
  ],
  "panels": [
    {
      "title": "Pool connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "$DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "db_pool_total",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "db_pool_idle",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "db_pool_waiting",
          "legendFormat": "waiting",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Pool utilization %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "$DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "100 * (db_pool_total - db_pool_idle) / clamp_min(db_pool_total, 1)",
          "legendFormat": "utilization",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Query duration p95 by op",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "$DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, op) (rate(db_query_duration_ms_bucket[5m])))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Slow queries RPS by op",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "$DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (op) (rate(db_slow_queries_total[5m]))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "DB errors by SQLSTATE code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "$DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (code) (rate(db_errors_total[5m]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["sergeant", "postgres"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Sergeant — Postgres Pool",
  "uid": "sergeant-db-pool",
  "version": 1
}
