        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": false,
      "icon": "doc",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "SLO.md",
      "tooltip": "Service Level Objectives",
      "type": "link",
      "url": "https://github.com/Skords-01/Sergeant/blob/main/docs/observability/SLO.md"
    },
    {
      "asDropdown": false,
      "icon": "doc",
