# ─────────────────────────────────────────────────────────────
# Hub — змінні середовища
# Скопіюйте цей файл у .env та заповніть значення.
# Ніколи не комітьте реальний .env у git.
# ─────────────────────────────────────────────────────────────

# Хто де: Railway (бекенд) — DATABASE_URL, BETTER_AUTH_SECRET, ANTHROPIC_API_KEY,
#   NUTRITION_API_TOKEN, USDA_FDC_API_KEY, VAPID_*, API_SECRET, ALLOWED_ORIGINS, PORT, AI_*.
# Vercel (фронт) — лише VITE_*; вони потрапляють у клієнтський бандл.
#   Не використовуйте префікс VITE_ для секретів (сесії, БД, приватні ключі API).
# Детальніше: docs/railway-vercel.md

# ── PostgreSQL ────────────────────────────────────────────────
# Локально (Docker): npm run db:up → postgresql://hub:hub@localhost:5432/hub
# Railway: змінна з сервісу Postgres або Reference ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://hub:hub@localhost:5432/hub

# ── Better Auth ───────────────────────────────────────────────
# Базова URL (автоматично визначається, якщо є REPLIT_DEV_DOMAIN)
BETTER_AUTH_URL=http://localhost:3000

# 0 = не форсити SameSite=None (якщо фронт і API на одному домені через proxy)
# BETTER_AUTH_CROSS_SITE_COOKIES=0

# Секрет для підпису сесійних кукі (мін. 32 символи)
BETTER_AUTH_SECRET=change_me_to_a_long_random_string_32chars

# ── Anthropic Claude API ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# Денні ліміти викликів AI (таблиця ai_usage_daily у Postgres). AI_QUOTA_DISABLED=1 — вимкнути.
# Залогінений користувач: AI_DAILY_USER_LIMIT (за замовч. 120). Без сесії — по IP: AI_DAILY_ANON_LIMIT (за замовч. 40).
# AI_DAILY_USER_LIMIT=120
# AI_DAILY_ANON_LIMIT=40
# AI_QUOTA_DISABLED=0

# ── Nutrition API Token ───────────────────────────────────────
# Використовується для захисту nutrition endpoints (опціонально)
NUTRITION_API_TOKEN=

# ── USDA FoodData Central (штрихкоди) ────────────────────────
# Безкоштовний ключ: https://api.data.gov/signup
# Без ключа використовується DEMO_KEY (40 req/hr shared limit).
USDA_FDC_API_KEY=

# ── Web Push / VAPID ─────────────────────────────────────────
# Згенеруйте: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# Внутрішній секрет для /api/push/send (щоб захистити від довільних запитів)
API_SECRET=change_me_to_a_random_string

# ── CORS ──────────────────────────────────────────────────────
# Через кому: додаткові origins, яким дозволено звертатись до API
ALLOWED_ORIGINS=http://localhost:5173

# ── Порт Express ─────────────────────────────────────────────
PORT=3000

# ── Vite (frontend, змінні з VITE_ — у клієнтському бандлі) ────
# Базова URL API для продакшн (якщо фронтенд і API на різних доменах)
VITE_API_BASE_URL=https://your-api.railway.app

# Якщо увімкнено NUTRITION_API_TOKEN на бекенді — той самий токен (публічний для клієнта)
VITE_NUTRITION_API_TOKEN=

# Proxy ціль в dev режимі (вказує на локальний Express)
VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# ── Replit (опціонально, авто-визначається) ───────────────────
# REPLIT_DEV_DOMAIN=your-repl.repl.co
# REPLIT_DOMAINS=your-repl.repl.co
