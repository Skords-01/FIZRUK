# Sergeant Operations Stack — environment variables
# Copy this file: cp .env.ops.example .env.ops
# Then fill in the values below.
# NEVER commit .env.ops to the repo.

# ── n8n ─────────────────────────────────────────────────────────
# Generate secrets:
#   N8N_PASSWORD=$(openssl rand -base64 24)
#   N8N_ENCRYPTION_KEY=$(openssl rand -hex 32)
#   N8N_DB_PASSWORD=$(openssl rand -base64 24)

N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/
N8N_USER=admin
# N8N_PASSWORD=<generate with: openssl rand -base64 24>
# N8N_ENCRYPTION_KEY=<generate with: openssl rand -hex 32>
# N8N_DB_PASSWORD=<generate with: openssl rand -base64 24>

# ── Telegram ops hub ────────────────────────────────────────────
# 1. Create bot via @BotFather → /newbot
# 2. Create private channel #sergeant-alerts, add bot as admin
# 3. Get CHAT_ID:
#    curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#    → find "chat":{"id":-100XXXXXXXXXX}

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ── Stripe (billing pipeline + failed payment recovery) ────────
# Stripe Dashboard → Developers → Webhooks → Signing secret
# Events: customer.subscription.created, invoice.payment_failed,
#          customer.subscription.deleted, charge.disputed

STRIPE_WEBHOOK_SECRET=

# ── Sentry (alert routing) ─────────────────────────────────────
# Sentry → Settings → Developer Settings → Internal Integration
# → Webhooks → enable "issue" events

SENTRY_WEBHOOK_SECRET=

# ── GitHub (Renovate PR auto-handler) ──────────────────────────
# GitHub → Settings → Developer settings → Personal access tokens
# Scopes: repo (read), pull_requests (write)
# Or use a GitHub App with webhook delivery

GITHUB_WEBHOOK_SECRET=
