{
  "extends": "@sergeant/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@finyk/*": ["./src/modules/finyk/*"],
      "@fizruk/*": ["./src/modules/fizruk/*"],
      "@routine/*": ["./src/modules/routine/*"],
      "@nutrition/*": ["./src/modules/nutrition/*"]
    }
  },
  "include": ["src/**/*", "vite.config.js", "vitest.config.js"],
  "exclude": ["node_modules", "dist", "src/sw.js"]
}
