{
  "name": "@sergeant/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --host 0.0.0.0",
    "build": "node scripts/check-imports.mjs && vite build",
    "build:analyze": "cross-env ANALYZE=1 node scripts/check-imports.mjs && cross-env ANALYZE=1 vite build",
    "preview": "vite preview",
    "lint": "eslint . && node scripts/check-imports.mjs",
    "lint:imports": "node scripts/check-imports.mjs",
    "test": "node scripts/vitest.mjs run",
    "test:watch": "node scripts/vitest.mjs",
    "test:a11y": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.sw.json --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "^8.55.1",
    "@tanstack/react-query": "^5.99.0",
    "better-auth": "^1.6.4",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "body-highlighter": "^3.0.2",
    "clsx": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.14.1",
    "react-virtuoso": "^4.18.5",
    "tailwind-merge": "^2.6.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@sergeant/config": "workspace:*",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.0.0"
  }
}
