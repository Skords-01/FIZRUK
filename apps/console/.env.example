# Sergeant Console — environment variables
# cp .env.example .env   then fill in values
# NEVER commit .env to the repo.

# ── Telegram ──────────────────────────────────────────────────
# Create bot via @BotFather → /newbot
CONSOLE_BOT_TOKEN=

# Comma-separated list of Telegram user IDs allowed to use the console.
# Get your ID by messaging @userinfobot.
# Leave empty to allow all users (NOT recommended for production).
ALLOWED_USER_IDS=

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Sergeant server (for internal API calls) ─────────────────
SERVER_INTERNAL_URL=http://localhost:3000
INTERNAL_API_KEY=

# ── Optional: external integrations ──────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# POSTHOG_API_KEY=
# POSTHOG_PROJECT_ID=
